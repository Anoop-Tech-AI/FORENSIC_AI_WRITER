# ============================================================
# FORENSIC WRITER - Environment Variables Reference
# Copy this file to .env and fill in real values
# NEVER commit the .env file to git!
# ============================================================

# ─────────────────── Server ───────────────────
NODE_ENV=production
PORT=5000

# ─────────────────── Database ─────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/forensic-writer?retryWrites=true&w=majority

# ─────────────────── Auth ─────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_jwt_secret_here

# ─────────────────── Frontend ─────────────────
# Your deployed Vercel frontend URL (no trailing slash)
CLIENT_URL=https://forensic-writer.vercel.app

# ─────────────────── AI Services ──────────────
# Hugging Face API Key (for Llama / Mistral models)
# Get from: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key_here

# Optional: URL of Python AI Server (Render service)
# If set, file/image analysis is routed here instead of Hugging Face
# AI_SERVER_URL=https://forensic-writer-ai-server.onrender.com

# ─────────────────── Email ────────────────────
# Gmail SMTP credentials for OTP emails
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─────────────────── Frontend Env (Vite) ──────
# Set this in client/.env file (not here)
# VITE_API_URL=https://forensic-writer-backend.onrender.com


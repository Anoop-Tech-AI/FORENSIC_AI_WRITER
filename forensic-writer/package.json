{
    "name": "forensic-writer-root",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "install-all": "npm install && cd server && npm install && cd ../client && npm install",
        "server": "cd server && npm run dev",
        "start": "node server/src/server.js",
        "client": "cd client && npm run dev",
        "dev": "concurrently \"npm run server\" \"npm run client\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "axios": "^1.18.1",
        "bcrypt": "^6.0.0",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "express-validator": "^7.3.2",
        "helmet": "^8.2.0",
        "joi": "^18.2.3",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.7.3",
        "morgan": "^1.11.0",
        "multer": "^2.2.0",
        "nodemailer": "^8.0.11",
        "pdfkit": "^0.19.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.1",
        "socket.io": "^4.8.3"
    }
}
